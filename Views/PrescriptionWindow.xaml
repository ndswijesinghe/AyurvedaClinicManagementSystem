<Window x:Class="AyurvedaClinicManagementSystem.Views.PrescriptionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Prescription Management"
        Height="600"
        Width="900"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="10">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">

            <TextBlock Text="Patient"/>
            <ComboBox x:Name="cmbPatient" Height="30" Margin="0,5"/>

            <TextBlock Text="Doctor"/>
            <ComboBox x:Name="cmbDoctor" Height="30" Margin="0,5"/>

            <TextBlock Text="Medicine"/>
            <ComboBox x:Name="cmbMedicine" Height="30" Margin="0,5"/>

            <TextBlock Text="Dosage"/>
            <TextBox x:Name="txtDosage"
                     Height="30"
                     Margin="0,5"/>

            <TextBlock Text="Prescription Date"/>
            <DatePicker x:Name="dpDate"
                        Margin="0,5"/>

            <StackPanel Orientation="Horizontal" Margin="0,10">

                <Button Content="Save"
                        Width="100"
                        Margin="5"
                        Background="Green"
                        Foreground="White"
                        Click="Save_Click"/>

                <Button Content="Delete"
                        Width="100"
                        Margin="5"
                        Background="Red"
                        Foreground="White"
                        Click="Delete_Click"/>

            </StackPanel>

        </StackPanel>

        <DataGrid x:Name="PrescriptionGrid"
                  Grid.Row="1"
                  Margin="5"
                  AutoGenerateColumns="True"/>

    </Grid>

</Window>