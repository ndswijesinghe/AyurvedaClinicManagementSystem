<Window x:Class="AyurvedaClinicManagementSystem.Views.BillWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Billing System"
        Height="600"
        Width="900"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="10">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- FORM -->
        <StackPanel Grid.Row="0">

            <TextBlock Text="Patient"/>
            <ComboBox x:Name="cmbPatient" Height="30" Margin="0,5"/>

            <TextBlock Text="Medicine"/>
            <ComboBox x:Name="cmbMedicine"
          Height="30"
          Margin="0,5"
          SelectionChanged="cmbMedicine_SelectionChanged"/>

            
            <TextBox x:Name="txtQuantity"
         Height="30"
         Margin="0,5"
         TextChanged="txtQuantity_TextChanged"/>

            <TextBlock Text="Price"/>
            <TextBox x:Name="txtPrice" Height="30" Margin="0,5"/>

            <TextBlock Text="Total"/>
            <TextBox x:Name="txtTotal" Height="30" Margin="0,5" IsReadOnly="True"/>

            <StackPanel Orientation="Horizontal" Margin="0,10">

                <Button Content="Add Item"
                        Width="120"
                        Margin="5"
                        Background="Green"
                        Foreground="White"
                        Click="AddItem_Click"/>

                <Button Content="Save Bill"
                        Width="120"
                        Margin="5"
                        Background="Blue"
                        Foreground="White"
                        Click="SaveBill_Click"/>

            </StackPanel>

        </StackPanel>

        <!-- GRID -->
        <DataGrid x:Name="BillGrid"
                  Grid.Row="1"
                  Margin="5"
                  AutoGenerateColumns="True"/>

    </Grid>
</Window>