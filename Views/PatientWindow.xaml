<Window x:Class="AyurvedaClinicManagementSystem.Views.PatientWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Patient Management"
        Height="600"
        Width="900"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="10">

        <!-- ROW STRUCTURE -->
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ================= INPUT FORM ================= -->
        <StackPanel Grid.Row="0" Orientation="Vertical">

            <TextBlock Text="First Name"/>
            <TextBox x:Name="txtFirstName" Height="30" Margin="0,5"/>

            <TextBlock Text="Last Name"/>
            <TextBox x:Name="txtLastName" Height="30" Margin="0,5"/>

            <TextBlock Text="Gender"/>
            <TextBox x:Name="txtGender" Height="30" Margin="0,5"/>

            <TextBlock Text="Phone"/>
            <TextBox x:Name="txtPhone" Height="30" Margin="0,5"/>

            <TextBlock Text="Address"/>
            <TextBox x:Name="txtAddress" Height="30" Margin="0,5"/>

            <TextBlock Text="Date of Birth"/>
            <DatePicker x:Name="dpDateOfBirth" Margin="0,5"/>

            <!-- BUTTONS -->
            <StackPanel Orientation="Horizontal" Margin="0,10">

                <Button Content="Save"
                        Width="100"
                        Margin="5"
                        Background="Green"
                        Foreground="White"
                        Click="SavePatient_Click"/>

                <Button Content="Update"
                        Width="100"
                        Margin="5"
                        Background="Orange"
                        Foreground="White"
                        Click="UpdatePatient_Click"/>

                <Button Content="Delete"
                        Width="100"
                        Margin="5"
                        Background="Red"
                        Foreground="White"
                        Click="DeletePatient_Click"/>

            </StackPanel>

        </StackPanel>

        <!-- ================= SEARCH BAR ================= -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="5">

            <TextBlock Text="Search Patient:"
                       VerticalAlignment="Center"
                       Margin="5"/>

            <TextBox x:Name="txtSearch"
                     Width="250"
                     Height="30"
                     Margin="5"
                     TextChanged="txtSearch_TextChanged"/>

        </StackPanel>

        <!-- ================= DATA GRID ================= -->
        <DataGrid x:Name="PatientGrid"
                  Grid.Row="2"
                  Margin="5"
                  AutoGenerateColumns="False"
                  SelectionChanged="PatientGrid_SelectionChanged">

            <DataGrid.Columns>

                <DataGridTextColumn Header="ID" Binding="{Binding PatientID}" />
                <DataGridTextColumn Header="First Name" Binding="{Binding FirstName}" />
                <DataGridTextColumn Header="Last Name" Binding="{Binding LastName}" />
                <DataGridTextColumn Header="Gender" Binding="{Binding Gender}" />
                <DataGridTextColumn Header="Phone" Binding="{Binding PhoneNumber}" />
                <DataGridTextColumn Header="Address" Binding="{Binding Address}" />

                <DataGridTextColumn Header="Date of Birth"
                                    Binding="{Binding DateOfBirth, StringFormat={}{0:yyyy-MM-dd}}" />

            </DataGrid.Columns>

        </DataGrid>

    </Grid>

</Window>