<Window x:Class="AyurvedaClinicManagementSystem.Views.DashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ayurveda Clinic Dashboard"
        Height="600"
        Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="#F4F6F8">

    <Grid>

        <!-- LEFT SIDEBAR -->
        <Border Background="#2C3E50"
                Width="220"
                HorizontalAlignment="Left">

            <StackPanel Margin="10">

                <TextBlock Text="AYURVEDA CLINIC"
                           Foreground="White"
                           FontSize="18"
                           FontWeight="Bold"
                           Margin="10"/>

                <Button Content="Dashboard"
                        Height="40"
                        Margin="5"/>

                <Button Content="Patients"
                        Height="40"
                        Margin="5"
                        Click="OpenPatient_Click"/>

                <Button Content="Doctor"
                        Height="40"
                        Margin="5"
                        Click="OpenDoctor_Click"/>

                <Button Content="Appointments"
                        Height="40"
                        Margin="5"
                        Click="Appointments_Click"/>

                <Button Content="Logout"
                        Height="40"
                        Margin="5"
                        Background="Red"
                        Foreground="White"/>
                <Button Content="Medicines"
                        Height="40"
                        Margin="5"
                        Click="OpenMedicine_Click"/>
                <Button Content="Billing"
        Height="40"
        Margin="5"
        Click="OpenBill_Click"/>
                <Button Content="Prescription"
        Height="40"
        Margin="5"
        Click="OpenPrescription_Click"/>

            </StackPanel>

        </Border>

        <!-- MAIN AREA -->
        <Grid Margin="220,0,0,0">

            <StackPanel>

                <TextBlock Text="Dashboard Overview"
                           FontSize="28"
                           FontWeight="Bold"
                           Margin="20"/>

                <WrapPanel Margin="20">

                    <!-- Patients -->
                    <Border Width="200"
                            Height="100"
                            Background="White"
                            Margin="10">

                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Patients"
                                       FontSize="16"
                                       HorizontalAlignment="Center"/>

                            <Label x:Name="lblPatients"
                                   Content="0"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"/>
                        </StackPanel>

                    </Border>

                    <!-- Doctors -->
                    <Border Width="200"
                            Height="100"
                            Background="White"
                            Margin="10">

                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Doctors"
                                       FontSize="16"
                                       HorizontalAlignment="Center"/>

                            <Label x:Name="lblDoctors"
                                   Content="0"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"/>
                        </StackPanel>

                    </Border>

                    <!-- Appointments -->
                    <Border Width="200"
                            Height="100"
                            Background="White"
                            Margin="10">

                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Appointments"
                                       FontSize="16"
                                       HorizontalAlignment="Center"/>

                            <Label x:Name="lblAppointments"
                                   Content="0"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"/>
                        </StackPanel>

                    </Border>

                </WrapPanel>

            </StackPanel>

        </Grid>

    </Grid>

</Window>