<Window x:Class="AyurvedaClinicManagementSystem.Views.AppointmentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Appointment Management"
        Height="550"
        Width="850"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="10">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- FORM -->
        <StackPanel Grid.Row="0">

            <TextBlock Text="Patient"/>
            <ComboBox x:Name="cmbPatient" Height="30" Margin="0,5"/>

            <TextBlock Text="Doctor"/>
            <ComboBox x:Name="cmbDoctor" Height="30" Margin="0,5"/>

            <TextBlock Text="Appointment Date"/>
            <DatePicker x:Name="dpDate" Margin="0,5"/>

            <TextBlock Text="Reason"/>
            <TextBox x:Name="txtReason" Height="30" Margin="0,5"/>

            <StackPanel Orientation="Horizontal" Margin="0,10">

                <Button Content="Save"
                        Width="120"
                        Margin="5"
                        Background="Green"
                        Foreground="White"
                        Click="Save_Click"/>

                <Button Content="Delete"
                        Width="120"
                        Margin="5"
                        Background="Red"
                        Foreground="White"
                        Click="Delete_Click"/>

            </StackPanel>
            <TextBlock Text="Search Appointment" Margin="5"/>

            <TextBox x:Name="txtSearchAppointment"
         Height="30"
         Margin="5"
         TextChanged="txtSearchAppointment_TextChanged"/>

        </StackPanel>
        

        <!-- GRID -->
        <DataGrid x:Name="AppointmentGrid"
                  Grid.Row="1"
                  Margin="5"
                  AutoGenerateColumns="True"
                  SelectionChanged="AppointmentGrid_SelectionChanged"/>

    </Grid>
</Window>